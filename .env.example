# PostgreSQL
POSTGRES_DB=research_rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Ollama (local LLM service)
OLLAMA_HOST=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2:3b
OLLAMA_VLM_MODEL=llava:13b

# LLM Provider
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_SECONDS=120

# Backend
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/research_rag
STORAGE_PATH=./storage

# API CORS
# Local: http://localhost:3000
# Production: https://your-frontend.vercel.app
CORS_ORIGINS=http://localhost:3000

# Storage Backend
# local: stores files on disk (dev)
# s3: S3-compatible object storage (recommended for deployment)
STORAGE_BACKEND=local

# S3/R2 Configuration (used when STORAGE_BACKEND=s3)
# Recommended free option: Cloudflare R2 (10 GB free storage + API calls)
# Reference: https://developers.cloudflare.com/r2/
STORAGE_S3_BUCKET=research-rag-storage
STORAGE_S3_REGION=auto
STORAGE_S3_ENDPOINT=https://<your-account-id>.r2.cloudflarestorage.com
STORAGE_S3_ACCESS_KEY=your_r2_access_key_id
STORAGE_S3_SECRET_KEY=your_r2_secret_access_key
STORAGE_FORCE_PATH_STYLE=true
STORAGE_PREFIX=research-rag
STORAGE_CACHE_PATH=./storage/cache

# Embedding Model (local)
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
# Change to 'cuda' if GPU available

# Generation Settings
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000

# Retrieval
TOP_K_VECTOR=10
TOP_K_GRAPH=5